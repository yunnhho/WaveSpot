# ============================================================
# WAVESPOT API — 환경변수 템플릿 (.env.example)
# cp .env.example .env 후 실제 값으로 교체
# ⚠️  JWT_SECRET은 반드시 32자 이상: openssl rand -base64 48
# ============================================================

# 서버
APP_PORT=3000
NODE_ENV=development

# 데이터베이스 (docker-compose 외부 포트 5433)
DATABASE_URL="postgresql://wavespot:wavespot_dev_2026@localhost:5433/wavespot"
REDIS_URL="redis://localhost:6379"

# JWT (32자 이상 필수)
JWT_SECRET="CHANGE_ME_USE_OPENSSL_RAND_BASE64_48_MIN_32_CHARS"
JWT_EXPIRES_IN="1h"
REFRESH_TOKEN_EXPIRES_IN="30d"

# 소셜 로그인
KAKAO_CLIENT_ID="{KAKAO_CLIENT_ID}"
GOOGLE_CLIENT_ID="{GOOGLE_CLIENT_ID}"
APPLE_CLIENT_ID="{APPLE_CLIENT_ID}"
APPLE_TEAM_ID="{APPLE_TEAM_ID}"
APPLE_KEY_ID="{APPLE_KEY_ID}"

# 기상청 / 해양조사원
KMA_API_KEY="{KMA_API_KEY}"
KHOA_API_KEY="{KHOA_API_KEY}"

# 네이버 지도
NAVER_MAP_CLIENT_ID="{NAVER_MAP_CLIENT_ID}"
NAVER_MAP_CLIENT_SECRET="{NAVER_MAP_CLIENT_SECRET}"

# Firebase Admin SDK
FIREBASE_PROJECT_ID="{FIREBASE_PROJECT_ID}"
FIREBASE_CLIENT_EMAIL="{FIREBASE_CLIENT_EMAIL}"
FIREBASE_PRIVATE_KEY="{FIREBASE_PRIVATE_KEY}"

# 포트원 v2
PORTONE_API_KEY="{PORTONE_API_KEY}"
PORTONE_WEBHOOK_SECRET="{PORTONE_WEBHOOK_SECRET}"

# Cloudflare R2
R2_ACCOUNT_ID="{R2_ACCOUNT_ID}"
R2_ACCESS_KEY="{R2_ACCESS_KEY}"
R2_SECRET_KEY="{R2_SECRET_KEY}"
R2_BUCKET_NAME="wavespot-media"

# 관리자 IP 화이트리스트
ADMIN_IP_WHITELIST="127.0.0.1"
