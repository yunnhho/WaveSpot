# ============================================
# WAVESPOT 환경변수 템플릿
# 이 파일을 `.env`로 복사 후 실제 값을 입력하세요
# cp .env.example .env
# ============================================

# Database (PostGIS)
DATABASE_URL=postgresql://wavespot:wavespot_dev_2026@localhost:5432/wavespot
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-min-32-chars-change-this
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# External APIs — 기상·해양 데이터
KMA_API_KEY=기상청_API_키
KHOA_API_KEY=국립해양조사원_API_키

# 네이버 지도
NAVER_MAP_CLIENT_ID=네이버_지도_클라이언트_ID
NAVER_MAP_CLIENT_SECRET=네이버_지도_시크릿

# Firebase (FCM 푸시 알림)
FIREBASE_PROJECT_ID=FCM_프로젝트_ID

# 포트원 v2 (결제)
PORTONE_API_KEY=포트원_API_키

# Cloudflare R2 (이미지 저장소)
R2_ACCOUNT_ID=클라우드플레어_계정_ID
R2_ACCESS_KEY=R2_액세스_키
R2_SECRET_KEY=R2_시크릿
R2_BUCKET_NAME=wavespot-media

# App
APP_PORT=3000
NODE_ENV=development
